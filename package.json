{
  "name": "fruit-for-all",
  "version": "1.0.0",
  "description": "open source orchard — a community map of free street fruit",
  "type": "module",
  "source": "client/index.html",
  "scripts": {
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "npm run copy:html && esbuild client/index.js --bundle --outdir=dist --servedir=dist --sourcemap --define:process.env.NODE_ENV=\\\"development\\\" --jsx=automatic --loader:.js=jsx --loader:.jsx=jsx --loader:.png=file --serve=3000",
    "dev:server": "nodemon --exec 'node --env-file=.env' server.js",
    "build": "npm run copy:html && esbuild client/index.js --bundle --outdir=dist --minify --define:process.env.NODE_ENV=\\\"production\\\" --jsx=automatic --loader:.js=jsx --loader:.jsx=jsx --loader:.png=file",
    "copy:html": "mkdir -p dist && cp client/map-index.html dist/index.html && cp loquat-48.png dist/loquat-48.png",
    "start": "node server.js",
    "test": "node --test tests/server/*.test.js tests/client/*.test.js",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/strangesongs/fruit-for-all.git"
  },
  "keywords": [
    "fruit",
    "map",
    "react",
    "leaflet",
    "los-angeles"
  ],
  "author": "j cretella",
  "license": "GPL-3.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "bugs": {
    "url": "https://github.com/strangesongs/fruit-for-all/issues"
  },
  "homepage": "https://github.com/strangesongs/fruit-for-all#readme",
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.896.0",
    "bcrypt": "^6.0.0",
    "compression": "^1.8.1",
    "express": "^4.19.2",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "leaflet": "^1.9.4",
    "node-fetch": "^3.3.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-leaflet": "^4.2.1",
    "resend": "^6.9.3",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.12",
    "concurrently": "^8.2.2",
    "esbuild": "^0.20.2",
    "husky": "^9.1.7",
    "nodemon": "^3.1.10",
    "prettier": "^3.2.5"
  },
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 Firefox versions",
    "last 2 Safari versions"
  ]
}
